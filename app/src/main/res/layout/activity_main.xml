<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Student\nRegistration"
            android:textColor="@color/text_primary"
            android:textSize="34sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.05"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSubHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Fill in your details below"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/accentBar"
            android:layout_width="44dp"
            android:layout_height="3dp"
            android:layout_marginTop="12dp"
            android:background="@color/accent_gold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubHeader" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardForm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/accentBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Full Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:letterSpacing="0.12"
                    android:text="FULL NAME"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_input"
                    android:hint="e.g. Budi Santoso"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp" />

                <!-- NIM -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:letterSpacing="0.12"
                    android:text="NIM"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <EditText
                    android:id="@+id/etNim"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_input"
                    android:hint="e.g. 12345678"
                    android:inputType="number"
                    android:paddingHorizontal="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp" />

                <!-- Study Program -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:letterSpacing="0.12"
                    android:text="STUDY PROGRAM"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <Spinner
                    android:id="@+id/spinnerProgram"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="18dp"
                    android:background="@drawable/bg_input"
                    android:entries="@array/study_programs"
                    android:paddingHorizontal="16dp" />

                <!-- Gender -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:letterSpacing="0.12"
                    android:text="GENDER"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <RadioGroup
                    android:id="@+id/rgGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbMale"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_radio_button"
                        android:button="@null"
                        android:gravity="center"
                        android:text="Male"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/rbFemale"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_radio_button"
                        android:button="@null"
                        android:gravity="center"
                        android:text="Female"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </RadioGroup>

                <!-- Hobbies -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:letterSpacing="0.12"
                    android:text="HOBBIES"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbCoding"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_checkbox"
                        android:button="@null"
                        android:paddingHorizontal="14dp"
                        android:text="💻 Coding"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <CheckBox
                        android:id="@+id/cbGaming"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_checkbox"
                        android:button="@null"
                        android:paddingHorizontal="14dp"
                        android:text="🎮 Gaming"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <CheckBox
                        android:id="@+id/cbReading"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_checkbox"
                        android:button="@null"
                        android:paddingHorizontal="14dp"
                        android:text="📚 Reading"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <CheckBox
                        android:id="@+id/cbDesign"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_checkbox"
                        android:button="@null"
                        android:paddingHorizontal="14dp"
                        android:text="🎨 Design"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                    <CheckBox
                        android:id="@+id/cbMusic"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_checkbox"
                        android:button="@null"
                        android:paddingHorizontal="14dp"
                        android:text="🎵 Music"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnShowProfile"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_button_primary"
            android:text="Show Profile  →"
            android:textColor="@color/btn_text"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            app:layout_constraintTop_toBottomOf="@id/cardForm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>